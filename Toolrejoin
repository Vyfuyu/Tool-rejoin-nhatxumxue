#!/data/data/com.termux/files/usr/bin/bash

# Khai báo màu sắc giao diện (ANSI Color)
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
PURPLE='\033[0;35m'
NC='\033[0m'

# Khởi tạo thư mục cấu hình và lưu trữ tĩnh
CONF_DIR="$HOME/.nhatxumxue_config"
mkdir -p "$CONF_DIR"

CONFIG_PKG="$CONF_DIR/config.pkg"
CONFIG_PLACE="$CONF_DIR/config.place"
CONFIG_VIP="$CONF_DIR/config.vip"
PID_FILE="$CONF_DIR/rejoin.pid"
START_TIME_FILE="$CONF_DIR/uptime.start"

# Khởi tạo thời gian chạy (Uptime) hệ thống nếu chưa có
if [ ! -f "$START_TIME_FILE" ]; then
    date +%s > "$START_TIME_FILE"
fi
START_TIME=$(cat "$START_TIME_FILE")

# Đọc tự động cấu hình đã lưu trước đó khi khởi động tool
[ -f "$CONFIG_PKG" ] && PKG=$(cat "$CONFIG_PKG") || PKG=""
[ -f "$CONFIG_PLACE" ] && PLACE_ID=$(cat "$CONFIG_PLACE") || PLACE_ID=""
[ -f "$CONFIG_VIP" ] && VIP_LINK=$(cat "$CONFIG_VIP") || VIP_LINK=""

# Hàm vẽ giao diện LOGO NHẬT XUM XUÊ độc quyền
print_logo() {
    clear
    echo -e "${CYAN}===================================================${NC}"
    echo -e "${PURPLE}  _   _ _   _    _ _____  __  _   _ __  __  __  _  ${NC}"
    echo -e "${PURPLE} | \ | | | | |  /_\_   _| \ \/ / | | |  \/  | \ \/ / ${NC}"
    echo -e "${PURPLE} |  \| | |_| | / _ \ | |    \  /  | | | |\/| |  \  /  ${NC}"
    echo -e "${PURPLE} |_|\__|\___/ /_/ \_\|_|    /_/\_\ \___/|_|  |_|  /_/\_\ ${NC}"
    echo -e ""
    echo -e "${YELLOW}           TOOL REJOIN ROBLOX AUTOMATIC            ${NC}"
    echo -e "${GREEN}             Bản Quyền: NHẬT XUM XUÊ               ${NC}"
    echo -e "${CYAN}===================================================${NC}"
}

# Hàm tính toán Uptime trực quan định dạng Giờ:Phút:Giây
get_uptime() {
    local now=$(date +%s)
    local diff=$((now - START_TIME))
    local hours=$((diff / 3600))
    local mins=$(((diff % 3600) / 60))
    local secs=$((diff % 60))
    printf "%02dh:%02dm:%02ds" $hours $mins $secs
}

# Chức năng 1: Quét tự động mặc định bằng Regex nghiêm ngặt
scan_roblox_default() {
    print_logo
    echo -e "${YELLOW}[*] Đang quét hệ thống tìm phiên bản Roblox mặc định...${NC}"
    sleep 1
    
    HAS_GLOBAL=$(pm list packages | grep "^package:com.roblox.client$")
    HAS_VNG=$(pm list packages | grep "^package:com.roblox.client.vnggames$")
    
    if [ -n "$HAS_GLOBAL" ] && [ -n "$HAS_VNG" ]; then
        echo -e "${BLUE}Tìm thấy cả 2 phiên bản Roblox trên máy:${NC}"
        echo -e "1. Roblox Quốc Tế (com.roblox.client)"
        echo -e "2. Roblox VNG (com.roblox.client.vnggames)"
        read -p "Vui lòng chọn bản muốn chạy (1 hoặc 2): " choice
        if [ "$choice" == "2" ]; then
            PKG="com.roblox.client.vnggames"
        else
            PKG="com.roblox.client"
        fi
    elif [ -n "$HAS_VNG" ]; then
        PKG="com.roblox.client.vnggames"
        echo -e "${GREEN}[✓] Đã nhận diện: Roblox VNG${NC}"
    elif [ -n "$HAS_GLOBAL" ]; then
        PKG="com.roblox.client"
        echo -e "${GREEN}[✓] Đã nhận diện: Roblox Quốc Tế${NC}"
    else
        echo -e "${RED}[!] Không quét thấy bản chuẩn nào. Tự gán bản VNG làm mặc định.${NC}"
        PKG="com.roblox.client.vnggames"
    fi
    
    echo "$PKG" > "$CONFIG_PKG"
    echo -e "\nẤn Enter để quay lại Menu..."
    read
}

# Chức năng 2: Nhập thông tin và Kích hoạt chạy ngầm liên tục không dừng
start_tool() {
    print_logo
    if [ -z "$PKG" ]; then
        echo -e "${RED}[!] Bạn chưa chọn gói ứng dụng Roblox. Tự động chọn bản VNG...${NC}"
        PKG="com.roblox.client.vnggames"
        echo "$PKG" > "$CONFIG_PKG"
    fi
    
    # 5. Kiểm tra bảo vệ vòng ngoài: Xác thực xem gói package có thực sự tồn tại trên máy không trước khi chạy
    if ! pm list packages | grep -q "^package:$PKG$"; then
        echo -e "${RED}[✗] Lỗi nghiêm trọng: Gói ứng dụng ($PKG) đã bị gỡ cài đặt khỏi máy!${NC}"
        echo -e "${YELLOW}[!] Vui lòng thực hiện Quét lại ứng dụng ở Tính năng [1] hoặc [5].${NC}"
        echo -e "\nẤn Enter để quay lại Menu..."
        read
        return
    fi
    
    echo -e "${BLUE}[👉] Nhập ID Game (Số) HOẶC Link Server VIP:${NC}"
    read -p "=> Nhập dữ liệu: " user_input
    
    # Kiểm tra tính hợp lệ dữ liệu đầu vào (Validation)
    if [[ "$user_input" =~ ^[0-9]+$ ]]; then
        PLACE_ID="$user_input"
        VIP_LINK=""
        echo "$PLACE_ID" > "$CONFIG_PLACE"
        rm -f "$CONFIG_VIP"
        echo -e "${GREEN}[✓] Đã ghi nhận Game ID hợp lệ: $PLACE_ID${NC}"
    elif [[ "$user_input" =~ "roblox.com" ]] || [[ "$user_input" =~ "roblox://" ]]; then
        VIP_LINK="$user_input"
        PLACE_ID=""
        echo "$VIP_LINK" > "$CONFIG_VIP"
        rm -f "$CONFIG_PLACE"
        echo -e "${GREEN}[✓] Đã ghi nhận Link Server VIP hợp lệ.${NC}"
    else
        echo -e "${RED}[✗] Lỗi: Dữ liệu không hợp lệ! Phải là dãy số ID hoặc link Roblox.${NC}"
        echo -e "\nẤn Enter để thoát ra nhập lại..."
        read
        return
    fi
    
    echo -e "${YELLOW}\n[!] Nhấn ENTER thêm một lần nữa để xác nhận KÍCH HOẠT...${NC}"
    read
    
    # 3 & 4. Chống trùng lặp tiến trình an toàn bằng PID: Hạ cấp từ kill -9 xuống kill tiêu chuẩn
    if [ -f "$PID_FILE" ]; then
        local old_pid=$(cat "$PID_FILE")
        if kill -0 "$old_pid" >/dev/null 2>&1; then
            kill "$old_pid" >/dev/null 2>&1
            sleep 0.5
            # Nếu tiến trình cứng đầu không chịu thoát mới ép buộc bằng -9
            kill -9 "$old_pid" >/dev/null 2>&1
        fi
    fi
    
    # 2. Thay thế `exec -a` bằng cấu trúc gọi nhánh `bash -c` chạy ngầm thuần túy để tương thích 100% mọi máy
    bash -c "
    while true
    do
        if ! pidof \"$PKG\" >/dev/null 2>&1
        then
            if [ -n \"$VIP_LINK\" ]; then
                am start -a android.intent.action.VIEW -d \"$VIP_LINK\" >/dev/null 2>&1
            elif [ -n \"$PLACE_ID\" ]; then
                am start -a android.intent.action.VIEW -d \"roblox://placeID=$PLACE_ID\" >/dev/null 2>&1
            fi
            sleep 30
        fi
        sleep 5
    done
    " &
    
    # Ghi nhận và lưu PID thực tế của tiến trình ngầm vừa tạo vào file cứng
    echo $! > "$PID_FILE"
    echo -e "${GREEN}[✓] HỆ THỐNG REJOIN ĐÃ ĐƯỢC KÍCH HOẠT CHẠY NGẦM THÀNH CÔNG!${NC}"
    sleep 1.5
}

# Chức năng 3: Reset toàn bộ dữ liệu cấu hình và dừng tác vụ về số 0
reset_all() {
    print_logo
    echo -e "${YELLOW}[*] Đang tiến hành dọn dẹp hệ thống và giải phóng bộ nhớ...${NC}"
    
    if [ -f "$PID_FILE" ]; then
        local active_pid=$(cat "$PID_FILE")
        kill "$active_pid" >/dev/null 2>&1
        kill -9 "$active_pid" >/dev/null 2>&1
    fi
    
    # 4. Xóa chọn lọc các file cấu hình, tuyệt đối bảo vệ và giữ vững cấu trúc thư mục/file uptime
    rm -f "$CONFIG_PKG" "$CONFIG_PLACE" "$CONFIG_VIP" "$PID_FILE"
    PKG=""
    PLACE_ID=""
    VIP_LINK=""
    
    # Khởi động lại bộ đếm thời gian Uptime
    date +%s > "$START_TIME_FILE"
    START_TIME=$(cat "$START_TIME_FILE")
    
    echo -e "${GREEN}[✓] Đã giải phóng toàn bộ tác vụ. Dữ liệu đã đưa về số 0!${NC}"
    echo -e "\nẤn Enter để quay trở lại Menu..."
    read
}

# Chức năng 5: Tìm kiếm nâng cao thông minh
scan_roblox_advanced() {
    print_logo
    echo -e "${YELLOW}[*] Đang tiến hành quét sâu diện rộng bằng từ khóa thông minh...${NC}"
    sleep 1
    
    # Thu thập danh sách gói ứng dụng chứa từ khóa "roblox" và loại bỏ chữ thừa ở đầu
    local map_packages=$(pm list packages | grep -i "roblox" | cut -d: -f2)
    
    # Đếm số lượng dòng kết quả thu được
    local count=0
    if [ -n "$map_packages" ]; then
        count=$(echo "$map_packages" | wc -l)
    fi
    
    if [ "$count" -eq 0 ]; then
        echo -e "${RED}[✗] Không quét thấy ứng dụng nào chứa từ khóa Roblox trong hệ thống!${NC}"
        echo -e "${YELLOW}[!] Giữ nguyên cấu hình hiện tại của bạn.${NC}"
    elif [ "$count" -eq 1 ]; then
        PKG=$(echo "$map_packages" | tr -d '\r' | xargs)
        echo -e "${GREEN}[✓] Đã tìm thấy duy nhất 1 bản và tự động gán: $PKG${NC}"
        echo "$PKG" > "$CONFIG_PKG"
    else
        echo -e "${BLUE}[!] Phát hiện thấy có $count phiên bản Roblox trên máy của bạn:${NC}"
        
        # Tạo Menu danh sách đánh số tự động
        local i=1
        echo "$map_packages" | while read -r line; do
            echo -e "  [$i] $line"
            i=$((i+1))
        done
        
        read -p "Vui lòng nhập số thứ tự bản bạn muốn chọn để Rejoin: " num_choice
        
        # Lọc chính xác tên gói theo dòng tương ứng mà người dùng chọn
        PKG=$(echo "$map_packages" | sed -n "${num_choice}p" | tr -d '\r' | xargs)
        
        if [ -z "$PKG" ]; then
            echo -e "${RED}[!] Nhập sai số thứ tự. Hệ thống tự chọn bản đầu tiên làm mẫu.${NC}"
            PKG=$(echo "$map_packages" | sed -n "1p" | tr -d '\r' | xargs)
        fi
        echo -e "${GREEN}[✓] Đã thiết lập thành công: $PKG${NC}"
        echo "$PKG" > "$CONFIG_PKG"
    fi
    
    echo -e "\nẤn Enter để quay lại Menu..."
    read
}

# Vòng lặp Menu điều khiển chính
while true
do
    print_logo
    
    # 1. FIX LỖI: Loại bỏ thuộc tính 'local' do biến đang nằm ngoài phạm vi Function
    current_pid=""
    if [ -f "$PID_FILE" ]; then
        current_pid=$(cat "$PID_FILE")
        if ! kill -0 "$current_pid" >/dev/null 2>&1; then
            current_pid=""
        fi
    fi

    # Bảng hiển thị Dashboard động
    echo -e " 📊 BẢNG TRẠNG THÁI HỆ THỐNG THỜI GIAN THỰC:"
    [ -n "$PKG" ] && echo -e "  • Phiên bản Roblox: ${GREEN}$PKG${NC}" || echo -e "  • Phiên bản Roblox: ${RED}Chưa cấu hình (Hãy chọn [1] hoặc [5])${NC}"
    [ -n "$PLACE_ID" ] && echo -e "  • Mã định danh Game: ${GREEN}$PLACE_ID${NC}"
    [ -n "$VIP_LINK" ] && echo -e "  • Đường dẫn VIP:     ${GREEN}Đã tích hợp link server${NC}"
    echo -e "  • Thời gian chạy tool: ${CYAN}$(get_uptime)${NC}"
    
    if [ -n "$current_pid" ]; then
        echo -e "  • Trạng thái Rejoin:   ${GREEN}ĐANG CHẠY NGẦM BỀN BỈ (PID: $current_pid)${NC}"
    else
        echo -e "  • Trạng thái Rejoin:   ${RED}ĐANG DỪNG HOẶC CHƯA BẮT ĐẦU${NC}"
    fi
    
    echo -e "${CYAN}===================================================${NC}"
    echo -e " ${YELLOW}[1]${NC} Tự động quét & Nhận diện Roblox (Mặc định)"
    echo -e " ${YELLOW}[2]${NC} Nhập ID / Link VIP Server & Kích hoạt chạy"
    echo -e " ${YELLOW}[3]${NC} Reset toàn bộ cấu hình hệ thống về số 0"
    echo -e " ${YELLOW}[4]${NC} Dừng tool & Thoát hoàn toàn giao diện"
    echo -e " ${YELLOW}[5]${NC} Quét sâu & Tìm kiếm nâng cao bằng từ khóa"
    echo -e "${CYAN}===================================================${NC}"
    read -p "Vui lòng nhập số tính năng bạn chọn (1-5): " menu_choice
    
    case $menu_choice in
        1) scan_roblox_default ;;
        2) start_tool ;;
        3) reset_all ;;
        4) 
            # 1. FIX LỖI: Loại bỏ thuộc tính 'local' tại case điều hướng menu
            if [ -f "$PID_FILE" ]; then
                exit_pid=$(cat "$PID_FILE")
                kill "$exit_pid" >/dev/null 2>&1
                kill -9 "$exit_pid" >/dev/null 2>&1
            fi
            rm -f "$PID_FILE"
            echo -e "${GREEN}Cảm ơn bạn đã tin dùng sản phẩm của NHẬT XUM XUÊ. Chào tạm biệt!${NC}"
            exit 0
            ;;
        5) scan_roblox_advanced ;;
        *) 
            echo -e "${RED}Lựa chọn không tồn tại trên hệ thống, vui lòng thử lại!${NC}"
            sleep 1
            ;;
    esac
done
